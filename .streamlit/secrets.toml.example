# Copy this file to .streamlit/secrets.toml (local) and also paste the same
# values into the Streamlit Cloud app's "Secrets" settings (for the public deploy).
# .streamlit/secrets.toml itself is gitignored — never commit real credentials.

# Password to unlock "我的持仓" / 交易记录 on the site.
app_password = "choose-a-password"

# The Google Sheet's ID — the long string in its URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
transactions_sheet_id = "paste-your-sheet-id-here"

# Paste the full contents of the service account JSON key you downloaded
# from Google Cloud Console here, as a TOML table.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project-id.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
